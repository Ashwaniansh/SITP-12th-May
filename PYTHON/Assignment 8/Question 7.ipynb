   "source": [
    "import pandas as pd\n",
    "\n",
    "df = pd.read_csv(r\"D:\\Data Science with AI & ML\\SITP-12th-May\\PANDAS\\sales.csv\")\n",
    "\n",
    "result = df.groupby('Item Type')['Total Revenue'].agg(\n",
    "    Highest_Sales='max',\n",
    "    Lowest_Sales='min',\n",
    "    Average_Sales='mean'\n",
    ")\n",
    "\n",
    "print(result)"
   ]
