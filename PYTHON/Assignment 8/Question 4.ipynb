    "\n",
    "import pandas as pd\n",
    "df = pd.read_csv(r\"D:\\Data Science with AI & ML\\SITP-12th-May\\PANDAS\\loan_approval.csv\")\n",
    "top_5 = (\n",
    "    df.groupby(\"city\")[\"income\"]\n",
    "      .mean()\n",
    "      .sort_values(ascending=False)\n",
    "      .head(5)\n",
    ")\n",
    "print(\"Top 5 Cities by Average Income:\")\n",
    "print(top_5)"
   ]
  }
