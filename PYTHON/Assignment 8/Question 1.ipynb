    "import numpy as np\n",
    "arr = np.random.randint(1, 100, 50)\n",
    "print(\"Array is given:\")\n",
    "print(arr)\n",
    "sorted_arr = np.sort(arr)\n",
    "second_largest = sorted_arr[-2]\n",
    "third_smallest = sorted_arr[2]\n",
    "print(\"\\n2nd Largest Element:\", second_largest)\n",
    "print(\"3rd Smallest Element:\", third_smallest)"
   ]
  }
