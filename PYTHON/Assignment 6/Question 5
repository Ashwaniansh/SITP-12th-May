class PrimeNumber:
    def check(self, x):
        if x > 1:
            for i in range(2, x):
                if x % i == 0:
                    print("This is not Prime Number.",x)
                    break
            else:
                print("This is Prime Number.",x)
        else:
            print("This is not Prime Number.",x)
n = int(input("Enter a number: "))
obj = PrimeNumber()
obj.check(n)