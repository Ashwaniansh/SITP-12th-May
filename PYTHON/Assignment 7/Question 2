class PrimeChecker:
    def check_prime(self, x):
        if x > 1:
            for i in range(2, x):
                if x % i == 0:
                    print(x, "is not a Prime Number")
                    break
            else:
                print(x, "is a Prime Number")
        else:
            print(x, "is not a Prime Number")
obj = PrimeChecker()
n = int(input("Enter a number: "))
obj.check_prime(n)